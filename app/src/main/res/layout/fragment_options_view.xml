<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_backgroundapp"
    tools:context=".view.FragmentOptionsView">

    <Button
        android:id="@+id/btnCancelOptions"
        android:layout_width="232dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_border_buttons"
        android:text="CANCEL"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnAcceptOptions"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/btnAcceptOptions"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tableLayout2"
        app:layout_constraintVertical_bias="0.216"
        android:layout_width="232dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_border_buttons"
        android:text="OK"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        tools:layout_editor_absoluteX="89dp"
        tools:layout_editor_absoluteY="589dp" />

    <TextView
        android:id="@+id/txtLblOptions"
        android:layout_width="348dp"
        android:layout_height="88dp"
        android:text="OPTIONS"
        android:textAlignment="center"
        android:textColor="#F6F6F6"
        android:textSize="60sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.507"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.055" />

    <TableLayout
        android:id="@+id/tableLayout2"
        android:layout_width="309dp"
        android:layout_height="347dp"
        android:background="@drawable/bg_color_menu"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtLblOptions"
        app:layout_constraintVertical_bias="0.184"
        >

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textView100"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textView200"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/txtLblLanguage"
                android:layout_width="156dp"
                android:layout_height="49dp"
                android:text="Language:"
                android:textAlignment="viewEnd"
                android:textColor="@color/white"
                android:textSize="30dp" />

            <CheckBox
                android:id="@+id/chkEnglishLanguage"
                android:layout_width="125dp"
                android:layout_height="65dp"
                android:text="English"
                android:buttonTint="@color/white"
                android:textColor="@color/white"
                android:textAlignment="viewStart"
                android:textSize="25dp" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/txtVacio"
                android:layout_width="156dp"
                android:layout_height="49dp"
                android:text=""
                android:textAlignment="viewStart"
                android:textColor="@color/white"
                android:textSize="30dp" />

            <CheckBox
                android:id="@+id/chkSpanishLanguage"
                android:layout_width="wrap_content"
                android:layout_height="65dp"
                android:text="Spanish"
                android:buttonTint="@color/white"
                android:textColor="@color/white"
                android:textAlignment="viewStart"
                android:textSize="25dp" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/textView300"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/txtLblSound"
                android:layout_width="125dp"
                android:layout_height="wrap_content"
                android:text="Sound:"
                android:textAlignment="viewEnd"
                android:textColor="@color/white"
                android:textSize="30dp" />

            <Switch
                android:id="@+id/switch1"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:trackTint="@color/white"
                android:textOn="ON"
                android:textOff="OFF"
                android:showText="true"
                android:textColor="@color/white"
                android:layout_gravity="start"
                android:thumb="@drawable/switch_thumb_custom"
                android:track="@drawable/switch_bg_custom"
                android:switchMinWidth="70dp" />
        </TableRow>

    </TableLayout>

</androidx.constraintlayout.widget.ConstraintLayout>