<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_backgroundapp"
    tools:context=".view.FragmentHomeView">

    <Button
        android:id="@+id/btnIdRegister"
        android:layout_width="232dp"
        android:layout_height="48dp"
        android:layout_marginBottom="180dp"
        android:background="@drawable/btn_border_buttons"
        android:onClick="changeActivityRegisterAcoount"
        android:text="REGISTER"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnIdLogin"
        app:layout_constraintVertical_bias="0.0" />

    <Button
        android:id="@+id/btnIdLogin"
        android:layout_width="232dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_border_buttons"
        android:onClick="changeActivityLogin"
        android:text="LOGIN"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lblFastAccessAppPrincipalTitle"
        app:layout_constraintVertical_bias="0.254" />

    <TextView
        android:id="@+id/lblFastAccessAppPrincipalTitle"
        android:layout_width="344dp"
        android:layout_height="69dp"
        android:fontFamily="@font/bomberescortcondital"
        android:text="FAST ACCESS APP"
        android:textAlignment="center"
        android:textColor="#0ea4af"
        android:textSize="38sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.492"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView32"
        app:layout_constraintVertical_bias="0.074" />

    <Button
        android:id="@+id/btnCreditsInformation"
        android:layout_width="51dp"
        android:layout_height="48dp"
        android:background="@drawable/img_information"
        android:onClick="changeActivityCredits"
        android:textSize="30sp"
        android:textStyle="bold|italic"
        android:contentDescription="Button to Credits"
        android:text=""
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.955"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.023" />

    <Button
        android:id="@+id/btnConfiguration"
        android:layout_width="51dp"
        android:layout_height="48dp"
        android:layout_marginBottom="592dp"
        android:background="@drawable/img_configuration"
        android:onClick="changeActivityOptions"
        android:contentDescription="Button to Configuration"
        android:text=""
        android:textSize="30sp"
        android:textStyle="bold|italic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.955"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnCreditsInformation"
        app:layout_constraintVertical_bias="0.027" />

    <ImageView
        android:id="@+id/imageView32"
        android:layout_width="177dp"
        android:layout_height="156dp"
        android:src="@drawable/img_startlogotype"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.154" />

</androidx.constraintlayout.widget.ConstraintLayout>